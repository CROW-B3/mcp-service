  token: {{apiKey}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 5,
    "method": "tools/call",
    "params": {
      "name": "crow_search_patterns",
      "arguments": {
        "query": "foot traffic peak hours",
        "organizationId": "{{orgId}}"
      }
    }
  }
}
