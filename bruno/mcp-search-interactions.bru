meta {
  name: MCP Search Interactions
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: bearer
}

auth:bearer {
  token: {{apiKey}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 4,
    "method": "tools/call",
    "params": {
      "name": "crow_search_interactions",
      "arguments": {
        "query": "purchase intent",
        "organizationId": "{{orgId}}"
      }
    }
  }
}
