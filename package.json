{
	"name": "mcp-service",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "workers-mcp docgen src/index.ts && wrangler deploy",
		"dev": "wrangler dev --env local --port 8011",
		"start": "wrangler dev",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"db:migrate:dev": "wrangler d1 migrations apply DB --env dev --remote",
		"db:migrate:prod": "wrangler d1 migrations apply DB --remote"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.8.71",
		"typescript": "^5.9.3",
		"vitest": "~3.2.4",
		"wrangler": "^4.57.0"
	},
	"dependencies": {
		"workers-mcp": "^0.0.13"
	}
}
